          <script>
/* ── Cursor ── */
            const cur = document.getElementById('cursor');
            const dot = document.getElementById('cursor-dot');
            const coords = document.getElementById('cursor-coords');
            let mx = 0, my = 0, cx = 0, cy = 0;
document.addEventListener('mousemove', e => {mx = e.clientX; my = e.clientY; coords.textContent = `${mx}, ${my}`; });
            (function moveCursor(){
              cx += (mx - cx) * 0.18;
            cy += (my - cy) * 0.18;
            cur.style.left = cx + 'px';
            cur.style.top  = cy + 'px';
            dot.style.left = mx + 'px';
            dot.style.top  = my + 'px';
            coords.style.left = mx + 'px';
            coords.style.top  = my + 'px';
            requestAnimationFrame(moveCursor);
})();

            /* ── Hero letter scatter ── */
            const nameEl = document.querySelector('.letter-row');
            const word = nameEl.dataset.word;
[...word].forEach((ch, i) => {
  const s = document.createElement('span');
            s.className = 'letter';
            s.textContent = ch;
            const rx = (Math.random() - 0.5) * 40;
            const ry = (Math.random() - 0.5) * 30;
            const rot = `${(Math.random() - 0.5) * 20}deg`;
            s.style.cssText = `--rx:${rx};--ry:${ry};--rot:${rot}`;
            if (ch === 'A' && i === 0) s.style.color = 'var(--acid)';
            nameEl.appendChild(s);
});

/* ── Redacted reveal ── */
document.querySelectorAll('.redact').forEach(el => {
              el.addEventListener('click', () => el.classList.toggle('revealed'));
});

            /* ── Periodic table ── */
            const elements = [
            {sym:'C',   name:'C Language',    num:'01', cat:'cat-lang' },
            {sym:'C++', name:'C Plus Plus',   num:'02', cat:'cat-lang' },
            {sym:'Py',  name:'Python',        num:'03', cat:'cat-lang' },
            {sym:'Jv',  name:'Java',          num:'04', cat:'cat-lang' },
            {sym:'Wp',  name:'WordPress',     num:'05', cat:'cat-frame' },
            {sym:'Ht',  name:'HTML5',         num:'06', cat:'cat-frame' },
            {sym:'Cs',  name:'CSS3',          num:'07', cat:'cat-frame' },
            {sym:'Ds',  name:'Data Science',  num:'08', cat:'cat-tool' },
            {sym:'Ml',  name:'ML Basics',     num:'09', cat:'cat-tool' },
            {sym:'Gi',  name:'Git',           num:'10', cat:'cat-tool' },
            {sym:'Lx',  name:'Linux CLI',     num:'11', cat:'cat-tool' },
            {sym:'Ql',  name:'SQL Basics',    num:'12', cat:'cat-tool' },
            {sym:'Qk',  name:'Quick Learn',   num:'13', cat:'cat-soft' },
            {sym:'Co',  name:'Collab',        num:'14', cat:'cat-soft' },
            {sym:'Ps',  name:'Prob. Solve',   num:'15', cat:'cat-soft' },
            {sym:'Ad',  name:'Adaptable',     num:'16', cat:'cat-soft' },
            ];
            const grid = document.getElementById('periodicGrid');
elements.forEach((el, i) => {
  const d = document.createElement('div');
            d.className = 'element reveal';
            d.style.transitionDelay = (i * 0.04) + 's';
            d.innerHTML = `
            <span class="el-num">${el.num}</span>
            <span class="el-sym">${el.sym}</span>
            <span class="el-name">${el.name}</span>
            <span class="el-cat ${el.cat}"></span>
            `;
            grid.appendChild(d);
});

/* ── Intersection Observer (scroll reveals) ── */
const observer = new IntersectionObserver((entries) => {
              entries.forEach(e => {
                if (e.isIntersecting) {
                  e.target.classList.add('visible');
                  if (e.target.classList.contains('scan-reveal')) {
                    setTimeout(() => e.target.classList.add('scanned'), 100);
                  }
                  observer.unobserve(e.target);
                }
              });
}, {threshold: 0.08 });

document.querySelectorAll('.reveal, .scan-reveal').forEach(el => observer.observe(el));
          </script>
